# ─────────────────────────────────────────────────────────────────────────────
# Box authentication
# Pick ONE of the two options below.
# ─────────────────────────────────────────────────────────────────────────────

# Option A (recommended for a live demo): short-lived Developer Token.
# Generate it in the Box Developer Console → your app → "Generate Developer Token".
# It expires after 60 minutes, which is fine for a webinar.
BOX_DEVELOPER_TOKEN=

# Option B (fallback): Client Credentials Grant (server-to-server, auto-refreshing).
# Your Box app must be "Server Authentication (Client Credentials Grant)" and
# authorized in the Admin Console. Provide client id/secret + ONE subject:
#   - BOX_USER_ID        → act as a specific user (your own account)
#   - BOX_ENTERPRISE_ID  → act as the enterprise service account
BOX_CLIENT_ID=
BOX_CLIENT_SECRET=
BOX_USER_ID=
# BOX_ENTERPRISE_ID=

# The Box folder that holds the knowledge base the agent is allowed to search.
# Copy it from the folder URL: https://app.box.com/folder/<THIS_ID>
# `bun run seed` prints this id after it uploads the fixtures.
BOX_ROOT_FOLDER_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Model provider — set ONE key. OpenAI is used if both are present.
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Optional model overrides.
# NOTE: as of mid-2026 `gpt-5.5-mini` is not yet GA in the API. Until it ships,
# use a working model such as `gpt-5-mini` or `gpt-5.5`.
OPENAI_MODEL=gpt-5.5-mini
ANTHROPIC_MODEL=claude-sonnet-4-5

# ─────────────────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────────────────
PORT=3000

# ─────────────────────────────────────────────────────────────────────────────
# Deployment — required by `bun run deploy` (langgraphjs deploy).
# Create a key at https://smith.langchain.com/settings.
# ─────────────────────────────────────────────────────────────────────────────
LANGSMITH_API_KEY=

# Shared secret the deployed UI's `/lg` proxy injects so the custom auth handler
# (agent/auth.ts) trusts it. Keeps the graph API private without putting any
# credential in the browser. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
UI_PROXY_SECRET=
