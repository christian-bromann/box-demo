{
  "name": "box-deepagents-knowledge-assistant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Enterprise Knowledge Assistant — a streaming RAG agent built on Box + LangChain Deep Agents",
  "scripts": {
    "dev": "run-p --race dev:web dev:agent",
    "dev:web": "vite",
    "dev:agent": "langgraphjs dev --port 2024 --host 127.0.0.1 --no-browser",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "run-s deploy:ui deploy:agent",
    "deploy:ui": "UI_BASE=/ui/ vite build",
    "deploy:agent": "langgraphjs deploy --remote",
    "seed": "bun scripts/seed.ts",
    "whoami": "bun scripts/whoami.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.5.1",
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "1.3.7",
    "@langchain/openai": "^1.5.3",
    "@langchain/react": "^1.0.26",
    "@radix-ui/react-avatar": "^1.2.1",
    "@radix-ui/react-scroll-area": "^1.2.13",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.11",
    "box-node-sdk": "^10.12.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "deepagents": "1.10.0",
    "hono": "^4.12.27",
    "langchain": "1.4.6",
    "lucide-react": "^1.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@langchain/langgraph-cli": "^1.4.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/bun": "latest",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "npm-run-all2": "^9.0.2",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.2"
  },
  "overrides": {
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "1.3.7",
    "@langchain/langgraph-checkpoint": "1.0.4",
    "langchain": "1.4.6",
    "deepagents": "1.10.0"
  }
}